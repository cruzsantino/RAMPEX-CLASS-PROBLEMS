import java.util.*;
import java.io.*;
class Main{
  public static void main(String[] args){
    Scanner sc=new Scanner(System.in);
    int len=sc.nextInt();
    int brth=sc.nextInt();
    for(int i=1;i<=len*brth;i++){
      System.out.print("* ");
      if(i%brth==0)
      System.out.println();
    }
  }
}
